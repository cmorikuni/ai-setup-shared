#!/usr/bin/env zsh
# Run the AI orchestrator in patch mode (bugfixes on existing code).
# Usage: patch-ai <spec-file>
set -e

SPEC_FILE="${1:-.ai-spec.md}"
ORCHESTRATOR="${AI_ORCHESTRATOR:-$HOME/ai-setup/ai-orchestrator}/orchestrator.py"

if [[ ! -f "$SPEC_FILE" ]]; then
    echo "[patch-ai] spec not found: $SPEC_FILE" >&2
    exit 1
fi

python3 "$ORCHESTRATOR" --patch "$SPEC_FILE"
